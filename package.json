{
  "name": "@dcyfr/ai-code-gen",
  "version": "1.0.0",
  "description": "AI-powered code generation toolkit - template generators, AST manipulation, intelligent scaffolding, and AI-assisted refactoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dcyfr-codegen": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:run": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "examples:compile": "tsc --noEmit --module nodenext --moduleResolution nodenext --target es2022 --strict --esModuleInterop true --skipLibCheck true examples/ast-refactoring.ts examples/custom-generator.ts",
    "examples:check": "npm run examples:compile",
    "examples:test": "npm run examples:check",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test:run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.8",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "memfs": "^4.14.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.0"
  },
  "keywords": [
    "code-generation",
    "ai",
    "typescript",
    "ast",
    "scaffolding",
    "templates",
    "refactoring",
    "dcyfr"
  ],
  "author": "DCYFR Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr/dcyfr-ai-code-gen.git"
  },
  "homepage": "https://github.com/dcyfr/dcyfr-ai-code-gen#readme",
  "bugs": {
    "url": "https://github.com/dcyfr/dcyfr-ai-code-gen/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
